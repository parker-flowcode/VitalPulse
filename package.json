{
  "name": "vitalpulse",
  "version": "5.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "description": "Monitor cardiovascular personal. Mide tu pulso y estima tu presión arterial usando la cámara de tu móvil.",
  "author": "MVP Software Studios",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/parker-flowcode/VitalPulse"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "npx eslint src/",
    "build:android:dev": "npx eas build --platform android --profile development",
    "build:android:preview": "npx eas build --platform android --profile preview",
    "build:android:prod": "npx eas build --platform android --profile production",
    "build:android:apk": "npx eas build --platform android --profile production-apk",
    "build:ios:dev": "npx eas build --platform ios --profile development",
    "build:ios:prod": "npx eas build --platform ios --profile production",
    "submit:android": "npx eas submit --platform android --profile production",
    "submit:ios": "npx eas submit --platform ios --profile production",
    "clean": "npx expo start --clear"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^6.3.29",
    "expo": "54.0.36",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.3.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vision-camera": "^4.7.3",
    "react-native-worklets": "^0.5.1",
    "react-native-worklets-core": "^1.3.3",
    "victory-native": "^36.9.1",
    "vision-camera-resize-plugin": "^3.2.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "react-test-renderer": "19.1.0"
  }
}
